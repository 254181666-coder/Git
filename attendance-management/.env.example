# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=attendance

# 应用配置
APP_NAME=考勤工资管理系统
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS 配置
CORS_ORIGINS=http://localhost:8010,http://127.0.0.1:8010

# 管理员账号（第一次启动时自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# 密钥配置（用于签名等）
SECRET_KEY=your-secret-key-here-change-in-production
