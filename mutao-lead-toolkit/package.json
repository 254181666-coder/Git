{
  "name": "lead-toolkit",
  "productName": "木桃工具包",
  "version": "0.1.3",
  "private": true,
  "description": "本地运行的线索监控、人工确认和客户跟进工具包。",
  "author": "灵数工坊",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "serve": "node server.js",
    "desktop": "electron .",
    "pack": "electron-builder --dir",
    "build:win": "electron-builder --win nsis --x64",
    "license:create": "node scripts/generate-license.js",
    "icon:build": "node scripts/make-icon.js"
  },
  "build": {
    "appId": "com.local.leadtoolkit",
    "productName": "木桃工具包",
    "asar": true,
    "files": [
      "electron-main.js",
      "server.js",
      "index.html",
      "license-public.pem",
      "assets/icon.ico",
      "assets/icon.png",
      "data/seed.json",
      "README.md",
      "docs/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "木桃工具包-${version}-安装包.${ext}"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "木桃工具包",
      "language": "2052",
      "displayLanguageSelector": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
