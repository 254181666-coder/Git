[Unit]
Description=Mutao License Center
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/mutao-license-center
EnvironmentFile=/etc/mutao-license-center.env
ExecStart=/usr/bin/node server.js
Restart=always
RestartSec=5
User=mutao
Group=mutao
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/mutao-license-center

[Install]
WantedBy=multi-user.target
