# Copy to /etc/mutao-license-center.env and adjust values before starting systemd.

NODE_ENV=production
HOST=127.0.0.1
PORT=8795

# Keep runtime data outside the application directory so deploys do not overwrite it.
HKT_DATA_DIR=/var/lib/mutao-license-center

# Public backend mode for the commercial license/admin console.
HKT_LICENSE_CENTER=1
HKT_AUTO_LICENSE=0

# Private key used to generate/renew customer authorization codes.
# Generate or copy the private key on the server, then chmod 600 it.
HKT_LICENSE_PRIVATE_KEY_PATH=/etc/mutao-license-center/license-private.pem

# Used by customer desktop clients for short-code activation and daily online checks.
# Example: https://license.example.com
HKT_LICENSE_SERVER_URL=https://YOUR_LICENSE_DOMAIN

# Desktop clients check at least hourly. Default is 24h.
HKT_LICENSE_CHECK_INTERVAL_MS=86400000
